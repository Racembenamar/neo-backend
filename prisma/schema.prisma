// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  @@map("admins")
}

model Player {
  id           String        @id @default(uuid())
  username     String        @unique
  passwordHash String?
  name         String
  email        String?       @unique
  emailVerified Boolean      @default(false)
  googleId     String?       @unique
  authProvider String        @default("password")
  passwordResetCodeHash String?
  passwordResetExpiresAt DateTime?
  phone        String?
  avatarSeed   String?
  avatarUrl    String?
  storeLinks   PlayerStore[]
  sessions     Session[]
  purchases    Purchase[]
  qrPayments   QrPayment[]
  ownedStore   Store?        @relation("StoreOwner")
  tournaments  TournamentParticipant[]
  deviceTokens DeviceToken[]
  matchesAsPlayer1 Match[]     @relation("Player1")
  matchesAsPlayer2 Match[]     @relation("Player2")
  pendingCashOrders PendingCashOrder[]
  notifications Notification[]
  createdWorkers StoreWorker[] @relation("WorkerCreator")
  creditTransactions CreditTransaction[]
  createdAt    DateTime      @default(now())

  @@map("players")
}

model Store {
  id            String             @id @default(uuid())
  name          String
  address       String?
  phone         String?
  logoUrl       String?
  city          String?
  route         String?
  description   String?
  instagramUrl  String?
  facebookUrl   String?
  discordUrl    String?
  bannerUrl     String?
  websiteUrl    String?
  openingHours  String?
  wifiSsid      String?
  wifiPassword  String?
  googleMapsUrl String?
  isActive      Boolean            @default(true)
  owner         Player             @relation("StoreOwner", fields: [ownerId], references: [id])
  ownerId       String             @unique
  gameTypes     GameType[]
  playerLinks   PlayerStore[]
  sessions      Session[]
  purchases     Purchase[]
  tierConfig    TierConfig?
  qrPayments    QrPayment[]
  products      Product[]
  tournaments   Tournament[]
  notifications Notification[]
  pendingCashOrders PendingCashOrder[]
  workers       StoreWorker[]
  creditTransactions CreditTransaction[]
  createdAt     DateTime           @default(now())

  @@map("stores")
}

model StoreWorker {
  id               String     @id @default(uuid())
  store            Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeId          String
  createdByOwner   Player     @relation("WorkerCreator", fields: [createdByOwnerId], references: [id], onDelete: Cascade)
  createdByOwnerId String
  username         String     @unique
  passwordHash     String
  name             String
  phone            String?
  permissions      Json
  isActive         Boolean    @default(true)
  sessions         Session[]
  purchases        Purchase[]
  creditTransactions CreditTransaction[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([storeId])
  @@map("store_workers")
}

model PlayerStore {
  id             String   @id @default(uuid())
  player         Player   @relation(fields: [playerId], references: [id])
  playerId       String
  store          Store    @relation(fields: [storeId], references: [id])
  storeId        String
  tier           Int      @default(1)
  totalPoints    Int      @default(0)
  pendingUpgrade Boolean  @default(false)
  joinedAt       DateTime @default(now())
  notificationsMuted Boolean @default(false)

  @@unique([playerId, storeId])
  @@map("player_stores")
}

model TierConfig {
  id                 String @id @default(uuid())
  store              Store  @relation(fields: [storeId], references: [id])
  storeId            String @unique
  tier1Threshold     Int    @default(0)
  tier2Threshold     Int    @default(1000)
  tier3Threshold     Int    @default(5000)
  tier4Threshold     Int    @default(10000)
  tier5Threshold     Int    @default(25000)
  tier1Pct           Float  @default(5)
  tier2Pct           Float  @default(10)
  tier3Pct           Float  @default(15)
  tier4Pct           Float  @default(20)
  tier5Pct           Float  @default(25)
  pointsPerDt        Int    @default(50)
  shopCashbackPct    Float  @default(5)

  @@map("tier_configs")
}

model GameType {
  id           String        @id @default(uuid())
  store        Store         @relation(fields: [storeId], references: [id])
  storeId      String
  name         String
  pricingMode  String        // "hourly" | "per_game"
  pricePerUnit Float
  isActive     Boolean       @default(true)
  sessionItems SessionItem[]

  @@map("game_types")
}

model Session {
  id             String        @id @default(uuid())
  store          Store         @relation(fields: [storeId], references: [id])
  storeId        String
  player         Player        @relation(fields: [playerId], references: [id])
  playerId       String
  items          SessionItem[]
  totalAmount    Float
  cashAmount     Float         @default(0)
  creditAmount   Float         @default(0)
  paymentMethod  String        @default("cash")
  pointsEarned   Int
  paidWithPoints Int           @default(0)
  isPaid         Boolean       @default(false)
  syncedAt       DateTime?
  worker         StoreWorker?  @relation(fields: [workerId], references: [id], onDelete: SetNull)
  workerId       String?
  creditTransactions CreditTransaction[]
  createdAt      DateTime      @default(now())

  @@map("sessions")
}

model Purchase {
  id            String   @id @default(uuid())
  store         Store    @relation(fields: [storeId], references: [id])
  storeId       String
  player        Player   @relation(fields: [playerId], references: [id])
  playerId      String
  productName   String
  pointsSpent   Int
  cashSpent     Float?
  pointsEarned  Int?
  worker        StoreWorker? @relation(fields: [workerId], references: [id], onDelete: SetNull)
  workerId      String?
  createdAt     DateTime @default(now())

  @@map("purchases")
}

model CreditTransaction {
  id        String       @id @default(uuid())
  store     Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeId   String
  player    Player       @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId  String
  worker    StoreWorker? @relation(fields: [workerId], references: [id], onDelete: SetNull)
  workerId  String?
  session   Session?     @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  sessionId String?
  type      String       // charge | payment | adjustment
  amountDt  Float
  note      String?
  createdAt DateTime     @default(now())

  @@index([storeId, playerId])
  @@index([workerId])
  @@map("credit_transactions")
}

model SessionItem {
  id         String   @id @default(uuid())
  session    Session  @relation(fields: [sessionId], references: [id])
  sessionId  String
  gameType   GameType @relation(fields: [gameTypeId], references: [id])
  gameTypeId String
  quantity   Float
  subtotal   Float

  @@map("session_items")
}

model QrPayment {
  id             String   @id @default(uuid())
  player         Player   @relation(fields: [playerId], references: [id])
  playerId       String
  store          Store    @relation(fields: [storeId], references: [id])
  storeId        String
  pointsToDeduct Int
  token          String   @unique @default(uuid())
  isUsed         Boolean  @default(false)
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  @@map("qr_payments")
}

model Product {
  id            String   @id @default(uuid())
  store         Store    @relation(fields: [storeId], references: [id])
  storeId       String
  name          String
  description   String?
  priceInPoints Int?
  priceInDt     Float?
  imageUrl      String?
  isActive      Boolean  @default(true)
  pendingCashOrders PendingCashOrder[]
  createdAt     DateTime @default(now())

  @@map("products")
}

model PendingCashOrder {
  id           String   @id @default(uuid())
  player       Player   @relation(fields: [playerId], references: [id])
  playerId     String
  store        Store    @relation(fields: [storeId], references: [id])
  storeId      String
  product      Product  @relation(fields: [productId], references: [id])
  productId    String
  amountDt     Float
  pointsToEarn Int
  status       String   @default("pending") // pending, completed, cancelled
  createdAt    DateTime @default(now())

  @@map("pending_cash_orders")
}

model Tournament {
  id               String   @id @default(uuid())
  store            Store    @relation(fields: [storeId], references: [id])
  storeId          String
  name             String
  date             DateTime
  prizePool        String
  prizeDistribution String?
  entryPrice       String?  @default("Gratuit")
  maxPlayers       Int
  registeredPlayers Int     @default(0)
  status           String   @default("open")
  isActive         Boolean  @default(true)
  groupPointsApproved Boolean @default(false)
  imageUrl         String?
  format           String   @default("single_elimination")
  groupSize        Int?
  advancingCount   Int?     @default(2)
  blockedSlots     String?
  schedulingRange  Int      @default(7)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  participants     TournamentParticipant[]
  matches          Match[]

  @@map("tournaments")
}

model TournamentParticipant {
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tournamentId String
  player       Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId     String
  status       String     @default("pending") // pending, accepted, rejected
  group        String?
  registeredAt DateTime   @default(now())

  @@id([tournamentId, playerId])
  @@map("tournament_participants")
}

model DeviceToken {
  id        String   @id @default(uuid())
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId  String
  token     String   @unique
  language  String   @default("en")
  createdAt DateTime @default(now())

  @@map("device_tokens")
}

model Notification {
  id        String   @id @default(uuid())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeId   String
  player    Player?  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId  String?
  title     String
  body      String
  isRead    Boolean  @default(false)
  type      String?
  data      String?
  createdAt DateTime @default(now())

  @@map("notifications")
}

model Match {
  id             String         @id @default(uuid())
  tournament     Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tournamentId   String
  round          Int
  matchIndex     Int
  group          String?
  player1        Player?        @relation("Player1", fields: [player1Id], references: [id], onDelete: SetNull)
  player1Id      String?
  player2        Player?        @relation("Player2", fields: [player2Id], references: [id], onDelete: SetNull)
  player2Id      String?
  player1Score   Int            @default(0)
  player2Score   Int            @default(0)
  winnerId       String?
  tableNumber    String?
  posterUrl      String?
  status         String         @default("pending") // pending, live, completed
  scheduledAt    DateTime?
  proposedAt     DateTime?
  proposedById   String?
  scheduleStatus String         @default("unscheduled") // unscheduled, pending_approval, confirmed
  messages       MatchMessage[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@map("matches")
}

model MatchMessage {
  id        String   @id @default(uuid())
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId   String
  senderId  String
  text      String
  createdAt DateTime @default(now())

  @@map("match_messages")
}
